# shopsystem-starter environment — PLACEHOLDER values only.
#
# ZERO-INSTALL: you do NOT need to set anything up by hand. Copy this file to
# `.env` (`cp .env.example .env`) and bin/bootstrap fills the rest in — it
# resolves the floating image at run time and records the resolved digest
# here, and the single up-front auth gate captures the live credentials.
# NEVER commit real secret material: every value below is a placeholder.
#
# The agent-vault credential broker (the agent-vault service in compose.yaml)
# reads AGENT_VAULT_MASTER_PASSWORD to auto-unseal.

# Broker master password — auto-unseals the agent-vault broker. Replace with
# the master password generated when the broker is provisioned.
AGENT_VAULT_MASTER_PASSWORD=<changeme-broker-master-password>

# postgres superuser password (defaults to the product slug if unset).
POSTGRES_PASSWORD=<changeme-postgres-password>

# Resolved image (ADR-040 D3). LEAVE BLANK: bin/bootstrap resolves the
# floating image tag at run time and RECORDS the resolved digest here so the
# run is reproducible without the committed compose pinning a tag.
BC_BASE_IMAGE_RESOLVED=
