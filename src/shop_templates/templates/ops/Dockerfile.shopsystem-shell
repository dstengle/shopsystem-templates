# Dockerfile.shopsystem-shell — lead-shop daily-driver shell image recipe
# (shop-owned, PDR-003 path F).
#
# Build locally when no published shopsystem-shell image is available:
#
#     docker build -t shopsystem-shell:dev -f Dockerfile.shopsystem-shell .
#
# This recipe may later be retired in favor of bc-launcher's published
# shopsystem-shell image; ship it now to unblock docker-only onboarding.
#
# Rebased onto the same devcontainer base image the lead host and
# bc-launcher containers run. That base already ships a working docker CLI
# on PATH for the non-root vscode user plus Microsoft's docker-init.sh
# socket-GID reconciler, so the mounted docker socket is reachable without
# an explicit apt docker-cli install layer. bc-launcher is INTENTIONALLY
# OMITTED (private repo).
FROM ghcr.io/dstengle/devcontainer-python-node-claude:latest

# Run the shell as the non-root user shipped by the devcontainer base. The
# base image's socket-GID reconciler makes the mounted docker socket
# reachable for this user.
USER vscode

# Install the framework CLIs (shop-msg, scenarios, shop-templates) with
# pipx so the operator has the full shopsystem toolchain on PATH inside the
# shell. pipx ships on the devcontainer base for the vscode user.
RUN pipx install shop-msg \
    && pipx install scenarios \
    && pipx install shop-templates

WORKDIR /workspace

CMD ["/bin/bash"]
