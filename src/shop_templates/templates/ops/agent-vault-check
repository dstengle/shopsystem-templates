#!/usr/bin/env bash
# bin/agent-vault-check — non-fatal broker credential expiry advisory
# (shop-owned, PDR-003 path F).
#
# A soft startup probe that warns the operator when the product's GitHub PAT
# stored in the agent-vault broker is within 30 days of expiry. It is wired
# into bin/shop-shell as `bin/agent-vault-check || true`, so it must NEVER
# abort the calling shell: it exits 0 even when it emits a warning (the
# `|| true` in shop-shell is belt-and-suspenders, not the only guard).
#
# PRODUCT-SCOPED (lead-w87b / WS-2): the broker CONTAINER, NETWORK, and proxy
# host all derive from the bootstrap product slug ({{OPS_SLUG}}); the broker
# container matches the agent-vault service compose.yaml defines
# ({{OPS_SLUG}}-agent-vault). Every product-scoped token is rendered from the
# slug; none is hardcoded to a specific product's broker or vault namespace.
#
# NON-FATAL: this script deliberately does NOT use `set -e`. Every probe is
# best-effort; a missing broker, a missing credential, or a parse failure
# downgrades to a soft advisory and the script still exits 0. That keeps a
# warning from killing the shop-shell startup it runs inside.
set -uo pipefail

# Source the single ops-coordinates artifact (ADR-043 Phase 1) — the broker
# container, vault, network, and address come from OPS_* defined there.
source "$(dirname "${BASH_SOURCE[0]}")/ops-coordinates"

# Threshold (days) below which we warn about impending GitHub-PAT expiry.
EXPIRY_WARN_DAYS=30

# -----------------------------------------------------------------------
# Broker coordinates — referenced from the sourced ops-coordinates artifact.
# -----------------------------------------------------------------------
CONTAINER="${AGENT_VAULT_CONTAINER:-$OPS_AGENT_VAULT_CONTAINER}"
VAULT="${AGENT_VAULT_VAULT:-$OPS_VAULT_NAME}"
NETWORK="${AGENT_VAULT_NETWORK:-$OPS_NETWORK}"
# The broker proxy host (the agent-vault service name on the product network).
PROXY_HOST="${AGENT_VAULT_PROXY_HOST:-$OPS_AGENT_VAULT_CONTAINER}"
# LOCAL-FIRST (lead-mrn2): the probe runs agent-vault on the LEAD HOST in agent
# mode and targets the broker at AGENT_VAULT_ADDR — NOT a docker exec into the
# broker container. AGENT_VAULT_TOKEN/_ADDR/_VAULT are sourced from the
# shop-shell .env that invokes this check.
AGENT_VAULT_ADDR="${AGENT_VAULT_ADDR:-$OPS_AGENT_VAULT_ADDR}"

# Best-effort: confirm the provisioned GitHub credential and read its expiry
# with a SINGLE local agent-vault command — NO docker exec into the broker, and
# no separate standalone `docker exec ... credential list` verification step.
# The credential key is GITHUB_TOKEN — the exact key bin/agent-vault-provision
# stores (the prior probe queried a non-existent credential key, so the
# advisory could never fire) — so the expiry advisory can actually
# fire. Any failure (no credential, broker unreachable, unparseable
# output) downgrades to a silent success — never a hard error.
EXPIRY_EPOCH=""
if GITHUB_PAT_VALUE="$(agent-vault vault credential get GITHUB_TOKEN --vault "$VAULT" 2>/dev/null)"; then
  # A GitHub PAT exposes its own expiry via the GitHub API response header
  # "GitHub-Authentication-Token-Expiration"; read it non-fatally.
  EXPIRY_RAW="$(curl -fsSI -H "Authorization: Bearer $GITHUB_PAT_VALUE" \
      https://api.github.com 2>/dev/null \
      | tr -d '\r' \
      | awk -F': ' 'tolower($1)=="github-authentication-token-expiration"{print $2}')"
  EXPIRY_EPOCH="$(date -d "$EXPIRY_RAW" +%s 2>/dev/null || true)"
fi

if [[ -z "$EXPIRY_EPOCH" ]]; then
  # Could not determine an expiry; nothing to warn about. Stay non-fatal.
  exit 0
fi

NOW_EPOCH="$(date +%s)"
SECONDS_LEFT=$(( EXPIRY_EPOCH - NOW_EPOCH ))
DAYS_LEFT=$(( SECONDS_LEFT / 86400 ))

if (( DAYS_LEFT <= EXPIRY_WARN_DAYS )); then
  echo "agent-vault-check: ADVISORY — the GitHub PAT in vault '$VAULT' on broker" >&2
  echo "  '$CONTAINER' (proxy '$PROXY_HOST', network '$NETWORK') expires in" >&2
  echo "  ${DAYS_LEFT} day(s) (threshold ${EXPIRY_WARN_DAYS}). Rotate it soon via" >&2
  echo "  bin/agent-vault-provision. This is a non-fatal advisory." >&2
fi

# Always succeed: this advisory must never abort the shop-shell startup.
exit 0
