#!/usr/bin/env bash
# bin/footing — lead-shop footing bootstrap script (shop-owned, PDR-003 path F).
#
# Run ONCE in a freshly forked "{{OPS_SLUG}}-lead" repository (carrying only
# the starter compose.yaml, this script, and .env.example — no framework code
# yet). It drives the product to SOLID FOOTING: the postgres + agent-vault
# services up, the lead structure poured, the product beads repo created, the
# git and beads remotes wired, and a successful first `git push` + `bd dolt
# push` proving the footing holds.
#
# It STOPS at footing. It does NOT enter product Discovery and it does NOT
# create any BC — those are downstream, agent-driven steps that begin only
# after a human has confirmed the footing. This script is the deterministic,
# pre-agent runway up to that line and no further.
#
# NO-AGENT CONTRACT: the footing phase launches NO agent. No `claude` session,
# no `bin/shop-shell` daily-driver shell, no `bc-launcher` (the downstream
# PM/Discovery BC launch) — nothing that starts a Claude or PM agent session
# appears as a step here. The runway is deterministic end to end; its ONLY
# non-deterministic step is the single human auth gate below. Agent sessions
# begin only AFTER a human confirms this footing, downstream of this script.
#
# PRODUCT-SCOPED: the data root, docker network, container-name greps, and
# the "{{OPS_SLUG}}-lead-beads" product beads repo all derive from the
# bootstrap product slug ({{OPS_SLUG}}) so this script never collides with a
# second product running alongside it.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

GITHUB_ORG="${GITHUB_ORG:-dstengle}"

# =======================================================================
# Validate the forked repo name and derive the product identity.
#
# The footing script runs in a freshly forked "<product>-lead" repository.
# The product slug is NOT baked in at render time — it is DERIVED from the
# fork's ACTUAL name so the same starter script footings any product. The
# fork's name is the repository directory's basename (the dir GitHub created
# when the "<product>-lead" repo was cloned).
#
#   1. Validate the name matches the "*-lead" shape (the lead-shop fork
#      convention). A name that does not end in "-lead" is rejected.
#   2. Derive the product slug by stripping the "-lead" suffix
#      (e.g. "acme-lead" -> "acme").
#   3. Record the derived slug as the declared product identity in the
#      product manifest (see "write the product manifest" below).
# =======================================================================
REPO_NAME="${FOOTING_REPO_NAME:-$(basename "$REPO_ROOT")}"
case "$REPO_NAME" in
  *-lead)
    : # accepted — the fork name matches the "*-lead" shape
    ;;
  *)
    # The forked repo name does NOT match the "*-lead" shape. Rather than
    # forcing the human to fork the starter template anew, offer to rename the
    # EXISTING repository in place to "<name>-lead" via `gh repo rename`. The
    # rename target is DERIVED from the actual repo name (append "-lead"), so
    # this works for any product, not a baked-in literal.
    RENAME_TARGET="${REPO_NAME}-lead"
    echo "footing: forked repository name '$REPO_NAME' does not match the required \"*-lead\" shape." >&2
    echo "  A lead-shop fork must be named '<product>-lead'. The starter template need not be forked again —" >&2
    echo "  rename the existing repository in place by running:" >&2
    echo "" >&2
    echo "    gh repo rename $RENAME_TARGET" >&2
    echo "" >&2
    echo "  then re-run footing from the renamed repository. Aborting." >&2
    exit 1
    ;;
esac
PRODUCT="${REPO_NAME%-lead}"

# Write the product manifest — the declared product identity for this fork.
# The derived slug is recorded under the "product:" key so every downstream
# footing step (and later agent-driven phases) reads one canonical product
# identity rather than re-deriving it.
PRODUCT_MANIFEST="${FOOTING_PRODUCT_MANIFEST:-$REPO_ROOT/.shop/product-manifest.yaml}"
mkdir -p "$(dirname "$PRODUCT_MANIFEST")"
{
  echo "# product manifest — declared product identity, written at footing."
  echo "product: $PRODUCT"
} > "$PRODUCT_MANIFEST"

# Slug-derived broker coordinates (mirrors bin/agent-vault-provision). Every
# <product>-* literal is rendered from {{OPS_SLUG}} at bootstrap.
AGENT_VAULT_CONTAINER="${AGENT_VAULT_CONTAINER:-{{OPS_SLUG}}-agent-vault}"
AGENT_VAULT_VAULT="${AGENT_VAULT_VAULT:-{{OPS_SLUG}}}"
# Claude-OAuth slot config (the oauth-typed proposal block the broker
# validates; token_url is REQUIRED on agent-vault 0.32.0). Same defaults the
# provision script verified against the live broker.
CLAUDE_OAUTH_TOKEN_URL="${CLAUDE_OAUTH_TOKEN_URL:-https://console.anthropic.com/v1/oauth/token}"
CLAUDE_OAUTH_CLIENT_ID="${CLAUDE_OAUTH_CLIENT_ID:-9d1c250a-e61b-44d9-88ed-5944d1962f5e}"
CLAUDE_OAUTH_SCOPES="${CLAUDE_OAUTH_SCOPES:-}"

# =======================================================================
# THE SINGLE UP-FRONT AUTH GATE (the ONLY human interaction in the run).
#
# All human authentication is consolidated here, ONCE, before any later
# footing step (the structure pour and the git/beads pushes). The gate
# collects three credentials in one place:
#
#   (a) the owner password for the agent-vault broker,
#   (b) the GitHub PAT (repo + delete_repo scope) used to create the product
#       beads repo and push, and
#   (c) the refreshing Claude OAuth credential — captured IN-SCRIPT by
#       creating an oauth-typed `agent-vault vault proposal` and having the
#       human APPROVE it via the CLI proposal flow only — no web/UI route;
#       approval is the `proposal approve <num> CLAUDE_OAUTH=<value> --yes` flow.
#
# After this gate the run is non-interactive through to solid footing: NO
# later step prompts the human for a credential again.
# =======================================================================
echo "footing: single up-front auth gate — collecting ALL human credentials now, once, before any later step." >&2

# (a) Owner password. Read it once, silently, here in the gate (never on argv,
#     never re-prompted later). Falls back to a pre-exported env var for a
#     fully non-interactive run.
OWNER_PASSWORD="${AGENT_VAULT_OWNER_PASSWORD:-}"
if [[ -z "$OWNER_PASSWORD" ]]; then
  read -r -s -p "footing[auth gate]: agent-vault owner password: " OWNER_PASSWORD
  echo >&2
fi
export AGENT_VAULT_OWNER_PASSWORD="$OWNER_PASSWORD"

# (b) GitHub PAT. Read it once, silently, here in the gate (never re-prompted
#     later). Falls back to a pre-exported env var for a non-interactive run.
GITHUB_TOKEN="${GITHUB_TOKEN:-}"
if [[ -z "$GITHUB_TOKEN" ]]; then
  read -r -s -p "footing[auth gate]: GitHub PAT (repo + delete_repo scope): " GITHUB_TOKEN
  echo >&2
fi
export GITHUB_TOKEN

# EMPTY-CREDENTIAL GUARD (lead-n7dq S4): after the gate, validate that BOTH the
# owner password and the GitHub PAT are non-empty. A blank value (an empty
# pre-export or an empty `read` fallback) would otherwise silently propagate
# into later steps — a blank owner password into the broker session, a blank
# PAT into the authenticated push. Abort with a diagnostic naming which is empty.
if [[ -z "$OWNER_PASSWORD" ]]; then
  echo "footing: the agent-vault owner password is EMPTY after the auth gate — aborting (set AGENT_VAULT_OWNER_PASSWORD or supply it at the gate)." >&2
  exit 1
fi
if [[ -z "$GITHUB_TOKEN" ]]; then
  echo "footing: the GitHub PAT is EMPTY after the auth gate — aborting (set GITHUB_TOKEN or supply it at the gate)." >&2
  exit 1
fi

# -----------------------------------------------------------------------
# Scripted .env initialization (lead-mrn2, scenario 9018e13b749bec95).
#
# The agent-vault broker auto-unseals from AGENT_VAULT_MASTER_PASSWORD in .env,
# so .env MUST exist carrying a real (generated, non-placeholder) master
# password BEFORE `docker compose up agent-vault`. Create .env from
# .env.example on a fresh shop and fill the two PRE-START values:
#   - AGENT_VAULT_MASTER_PASSWORD: a generated high-entropy secret (so the
#     broker can unseal), replacing the "<changeme-...>" placeholder.
#   - AGENT_VAULT_ADDR: the real in-network broker address the local-first ops
#     tools target, replacing the "<changeme-broker-address>" placeholder.
# The broker-dependent values (AGENT_VAULT_TOKEN/_VAULT/_CA_PEM) stay
# placeholders here; bin/agent-vault-provision fills them AFTER the broker is up.
# Operator-set real values are preserved (only placeholders/empties are filled).
# -----------------------------------------------------------------------
ENV_FILE="$REPO_ROOT/.env"
[[ -f "$ENV_FILE" ]] || cp "$REPO_ROOT/.env.example" "$ENV_FILE"
AGENT_VAULT_ADDR="${AGENT_VAULT_ADDR:-http://{{OPS_SLUG}}-agent-vault:14321}"
_GEN_MASTER_PW="$(head -c 32 /dev/urandom | base64 | tr -dc 'A-Za-z0-9' | head -c 40)"
_env_tmp="$(mktemp)"
while IFS= read -r line || [[ -n "$line" ]]; do
  case "$line" in
    AGENT_VAULT_MASTER_PASSWORD=\<changeme*|AGENT_VAULT_MASTER_PASSWORD=)
      printf 'AGENT_VAULT_MASTER_PASSWORD=%s\n' "$_GEN_MASTER_PW" ;;
    AGENT_VAULT_ADDR=\<changeme*|AGENT_VAULT_ADDR=)
      printf 'AGENT_VAULT_ADDR=%s\n' "$AGENT_VAULT_ADDR" ;;
    *)
      printf '%s\n' "$line" ;;
  esac
done < "$ENV_FILE" > "$_env_tmp"
mv "$_env_tmp" "$ENV_FILE"
export AGENT_VAULT_ADDR

# The agent-vault broker must be live before the oauth proposal can be created,
# so bring the footing services up as part of reaching the gate's OAuth step.
# (Broker bring-up is a prerequisite OF the gate, not a later footing step.)
# .env carries AGENT_VAULT_MASTER_PASSWORD now, so the broker auto-unseals.
docker compose -f "$REPO_ROOT/compose.yaml" up -d postgres agent-vault

if ! docker ps --format '{{.Names}}' | grep -Eq '^{{OPS_SLUG}}-postgres$|^{{OPS_SLUG}}-agent-vault$'; then
  echo "footing: expected the slug-scoped compose containers ({{OPS_SLUG}}-postgres / {{OPS_SLUG}}-agent-vault) to be running, but neither was found." >&2
  echo "  Check 'docker compose -f $REPO_ROOT/compose.yaml ps'. Aborting." >&2
  exit 1
fi

# -----------------------------------------------------------------------
# NETWORK SELF-ATTACH (lead-rs0i, scenarios 8b975a4b / 4caa8193).
#
# bin/bootstrap launches this footing container WITHOUT `--network`, so it
# begins on Docker's default bridge. `docker compose up` (above) created the
# user-defined "{{OPS_SLUG}}" network carrying the "{{OPS_SLUG}}-agent-vault"
# broker. A bridge container CANNOT DNS-resolve a user-network container name,
# so the local-first `agent-vault --address http://{{OPS_SLUG}}-agent-vault:14321`
# calls below would fail to resolve the broker. footing has the host docker
# socket, so it self-attaches its OWN container to the "{{OPS_SLUG}}" network
# now — AFTER infra-up and BEFORE the first --address call — so the in-network
# broker name resolves. Idempotent: a second attach (already a member) is a
# no-op (the "already exists in network" error is non-fatal here).
echo "footing: attaching this footing container to the '{{OPS_SLUG}}' network so the in-network broker name resolves." >&2
docker network connect "{{OPS_SLUG}}" "$(hostname)" 2>/dev/null || true

# BROKER-READINESS WAIT (lead-n7dq S3): the broker container has started but may
# not yet be LISTENING + unsealed on :14321. After the network self-attach (so
# the in-network name resolves) and BEFORE the first local-first agent-vault
# call, poll the broker on its in-network address with a bounded retry budget,
# so the first call does not hit a connection-refused race. Abort with a
# diagnostic naming the unready broker if the budget is exhausted.
echo "footing: waiting for the agent-vault broker to be ready at '$AGENT_VAULT_ADDR' (in-network)." >&2
_broker_ready=""
for _try in $(seq 1 60); do
  if curl -sS --max-time 3 -o /dev/null "$AGENT_VAULT_ADDR" 2>/dev/null; then
    _broker_ready=1
    break
  fi
  sleep 2
done
if [[ -z "$_broker_ready" ]]; then
  echo "footing: the agent-vault broker at '$AGENT_VAULT_ADDR' (container '{{OPS_SLUG}}-agent-vault') did not become ready within the retry budget — aborting." >&2
  exit 1
fi
echo "footing: agent-vault broker is ready at '$AGENT_VAULT_ADDR'." >&2

# (c) Claude OAuth credential — captured IN-SCRIPT via an oauth-typed proposal
#     the human APPROVES (reusing the bin/agent-vault-provision contract). The
#     proposal create/approve run in AGENT mode on agent-vault 0.32.0 and need
#     a vault-SCOPED session.
#
# LOCAL-FIRST (lead-mrn2): run agent-vault on the LEAD HOST against
# AGENT_VAULT_ADDR — NOT `docker exec` into the broker. Establish the owner
# session locally (auth login/register --address), mint the vault-scoped
# session locally, then run the proposal subcommands locally under the scoped
# session env.
AGENT_VAULT_OWNER_EMAIL="${AGENT_VAULT_OWNER_EMAIL:-owner@{{OPS_SLUG}}.local}"
if ! printf '%s' "$OWNER_PASSWORD" | agent-vault auth login --address "$AGENT_VAULT_ADDR" --email "$AGENT_VAULT_OWNER_EMAIL" --password-stdin 2>/dev/null; then
  printf '%s' "$OWNER_PASSWORD" | agent-vault auth register --address "$AGENT_VAULT_ADDR" --email "$AGENT_VAULT_OWNER_EMAIL" --password-stdin
fi
_SCOPED_SESSION="$(agent-vault vault token --vault "$AGENT_VAULT_VAULT" --address "$AGENT_VAULT_ADDR" | tr -d '\r\n')"
if [[ -z "$_SCOPED_SESSION" ]]; then
  echo "footing: failed to mint a vault-scoped session for the Claude OAuth proposal on vault '$AGENT_VAULT_VAULT'." >&2
  exit 1
fi
# Run the proposal subcommands LOCALLY under the vault-scoped session env.
DEXEC_SCOPED=(env \
  AGENT_VAULT_TOKEN="$_SCOPED_SESSION" \
  AGENT_VAULT_ADDR="$AGENT_VAULT_ADDR" \
  AGENT_VAULT_VAULT="$AGENT_VAULT_VAULT")

# The oauth-typed CLAUDE_OAUTH credential-slot proposal. action:set + type:oauth
# + the oauth block (token_url REQUIRED); the slot stores NO token value — the
# real secret arrives ONLY at approve-time (no automated step transports it).
_oauth_proposal_json="$(cat <<EOF
{"credentials":[{"action":"set","key":"CLAUDE_OAUTH","type":"oauth","oauth":{"token_url":"${CLAUDE_OAUTH_TOKEN_URL}","client_id":"${CLAUDE_OAUTH_CLIENT_ID}","scopes":"${CLAUDE_OAUTH_SCOPES}"},"description":"Claude OAuth","obtain_instructions":"paste accessToken+refreshToken at approve time"}],"message":"Provision the refreshing CLAUDE_OAUTH credential for vault ${AGENT_VAULT_VAULT}."}
EOF
)"
echo "footing[auth gate]: creating the oauth-typed CLAUDE_OAUTH proposal (vault '$AGENT_VAULT_VAULT')." >&2
_proposal_out="$(printf '%s' "$_oauth_proposal_json" | "${DEXEC_SCOPED[@]}" agent-vault vault proposal create -f - --json --vault "$AGENT_VAULT_VAULT")"
PROPOSAL_NUM="$(printf '%s' "$_proposal_out" | grep -oE '"(number|id)"[[:space:]]*:[[:space:]]*[0-9]+' | grep -oE '[0-9]+' | head -n1)"
if [[ -z "$PROPOSAL_NUM" ]]; then
  PROPOSAL_NUM="$("${DEXEC_SCOPED[@]}" agent-vault vault proposal list --status pending --vault "$AGENT_VAULT_VAULT" 2>/dev/null | grep -oE '[0-9]+' | tail -n1)"
fi

# Human APPROVES the proposal here, in the gate — via the CLI proposal flow
# only (no web/UI route). The real Claude OAuth secret is pasted in place
# of <value> AT APPROVE TIME; no automated step carries it.
cat <<EOF >&2

  ┌──────────────────────────────────────────────────────────────────────┐
  │ AUTH GATE — approve the Claude-OAuth proposal (CLI flow, one-time)     │
  └──────────────────────────────────────────────────────────────────────┘

  An oauth-typed CLAUDE_OAUTH credential-slot proposal
  (#${PROPOSAL_NUM:-<see 'agent-vault vault proposal list'>}) was created on
  vault '$AGENT_VAULT_VAULT'. Approve it by running this EXACT command FROM THE
  HOST — supply the real Claude OAuth secret in place of <claude-oauth-token>
  AT APPROVE TIME (no automated step carries the real secret; it is pasted only
  here):

    ./bin/agent-vault-approve-claude <claude-oauth-token>

  bin/agent-vault-approve-claude resolves the broker container, vault, and
  pending proposal from the host (via the docker socket) and runs the scoped
  approve — so the command is RUNNABLE from where you (the operator) run it,
  not only from the in-network '$AGENT_VAULT_ADDR' address that does not
  resolve on the host.

  This is the LAST human action in the footing run. footing WAITS below until
  this approval lands; the remaining steps then run with NO further credential.

EOF

# BLOCK-UNTIL-APPROVED (lead-n7dq S7): footing must NOT reach solid footing with
# an unapproved CLAUDE_OAUTH. Poll the vault locally until the approved
# CLAUDE_OAUTH credential lands (the host approve command above materializes
# it), so footing only proceeds once the approval is real.
echo "footing: waiting for the CLAUDE_OAUTH proposal (#${PROPOSAL_NUM:-<pending>}) to be approved on vault '$AGENT_VAULT_VAULT' — run './bin/agent-vault-approve-claude <token>' from the host now." >&2
until "${DEXEC_SCOPED[@]}" agent-vault vault credential list --vault "$AGENT_VAULT_VAULT" 2>/dev/null | grep -qw 'CLAUDE_OAUTH'; do
  sleep 5
done
echo "footing: CLAUDE_OAUTH approved on vault '$AGENT_VAULT_VAULT' — proceeding toward solid footing." >&2

# -----------------------------------------------------------------------
# Step 2 — pour the lead structure.
#
# Render the lead-shop framework structure into this repo in place. This is
# the same entry point an operator would otherwise run by hand; footing wires
# it into the sequence so the freshly forked repo gains its .claude/, role
# templates, ops scaffolding, and beads tracker deterministically.
# -----------------------------------------------------------------------
shop-templates bootstrap \
  --shop-type lead \
  --shop-name "{{OPS_SLUG}}-product" \
  --target "$REPO_ROOT"

# =======================================================================
# FORCED PRODUCT-SCOPED NAMING CONTRACT.
#
# Every repository the tooling creates is FORCED under the runtime-derived
# product slug ($PRODUCT, stripped from this fork's "<product>-lead" name
# above) — never a render-time literal and never an arbitrary name. The
# contract has one shape with no escape hatch:
#
#   * the lead beads repository  -> "$PRODUCT-lead-beads"
#   * any BC repository "<bc>"    -> "$PRODUCT-<bc>"
#   * that BC's beads repository  -> "$PRODUCT-<bc>-beads"
#
# i.e. EVERY tooling-created repository name matches the "$PRODUCT-*" shape.
# No tooling-created repository can be named outside that shape.
#
# Footing itself creates ONLY the lead beads repository (below); it creates
# NO BC — BC creation is a downstream, agent-driven step. The forced BC-repo
# convention is DECLARED and GUARDED here so that whatever downstream tooling
# later creates a BC is bound by the same product scope. The guard below is
# the single chokepoint that forces the shape: any tooling-created repo name
# is run through it and a name outside "$PRODUCT-*" is rejected.
# =======================================================================

# The forced BC-repo naming convention, derived from the runtime $PRODUCT.
# (DECLARED here, not invoked by footing — footing creates no BC. Downstream
# BC-creation tooling uses these to force every BC repo under the product.)
forced_bc_repo() {
  # A BC named "$1" is forced to the product-scoped repo name "$PRODUCT-<bc>".
  printf '%s' "$PRODUCT-${1:?forced_bc_repo: BC name required}"
}
forced_bc_beads_repo() {
  # That BC's beads repo is forced to "$PRODUCT-<bc>-beads".
  printf '%s' "$PRODUCT-${1:?forced_bc_beads_repo: BC name required}-beads"
}

# The single chokepoint that ENFORCES the forced shape: no tooling-created
# repository can be named outside the "$PRODUCT-*" shape. Every tooling-created
# repo name is run through this guard; a name that does not match "$PRODUCT-*"
# is rejected (the run aborts) rather than created off-scope.
assert_product_scoped_repo() {
  case "$1" in
    "$PRODUCT-"*)
      : # matches the forced "$PRODUCT-*" shape — accepted
      ;;
    *)
      echo "footing: refusing to create repository '$1' — no tooling-created repository may be named outside the \"$PRODUCT-*\" shape." >&2
      exit 1
      ;;
  esac
}

# -----------------------------------------------------------------------
# Step 3 — create the product beads repository.
#
# The bd tracker syncs to a sibling "$PRODUCT-lead-beads" repo (forced under
# the runtime-derived product slug) under the same GitHub org the framework
# ships from. Create it (idempotently) so the beads remote wired below has
# somewhere to push. The name is run through the product-scope guard first.
# -----------------------------------------------------------------------
BEADS_REPO="$PRODUCT-lead-beads"
assert_product_scoped_repo "$BEADS_REPO"
if ! gh repo view "$GITHUB_ORG/$BEADS_REPO" >/dev/null 2>&1; then
  # gh 2.95.0 REMOVED `--confirm`; passing it aborts under `set -e` on an
  # unknown-flag error (lead-n7dq S2). `gh repo create <name>` with no prompt
  # flags creates non-interactively given the name + --private.
  gh repo create "$GITHUB_ORG/$BEADS_REPO" --private
fi

# -----------------------------------------------------------------------
# Step 4 — wire the git and beads remotes.
#
# Point the repo's git "origin" at the forked "$PRODUCT-lead" repo and the
# bd dolt remote at the freshly created "$PRODUCT-lead-beads" repo. Both are
# forced under the runtime-derived product slug.
# -----------------------------------------------------------------------
GIT_REMOTE="https://github.com/$GITHUB_ORG/$PRODUCT-lead.git"
BEADS_REMOTE="git+https://github.com/$GITHUB_ORG/$PRODUCT-lead-beads.git"

if git remote get-url origin >/dev/null 2>&1; then
  git remote set-url origin "$GIT_REMOTE"
else
  git remote add origin "$GIT_REMOTE"
fi

if bd dolt remote list 2>/dev/null | grep -q '^origin'; then
  : # beads remote already wired
else
  bd dolt remote add origin "$BEADS_REMOTE"
fi

# -----------------------------------------------------------------------
# Step 5 — reach solid footing.
#
# Prove the footing holds end to end: a successful first `git push` of the
# poured structure and a successful `bd dolt push` of the beads tracker.
# These two pushes ARE the demonstration of solid footing.
# -----------------------------------------------------------------------
# GIT AUTHOR IDENTITY (lead-n7dq S5): configure user.email/user.name BEFORE the
# commit, derived from the owner email or a deterministic default, so the commit
# is a REAL commit on HEAD rather than failing for a missing identity and being
# swallowed by `|| true` (which would leave HEAD unborn and push nothing).
git config user.email "${GIT_AUTHOR_EMAIL:-${AGENT_VAULT_OWNER_EMAIL:-footing@{{OPS_SLUG}}.local}}"
git config user.name "${GIT_AUTHOR_NAME:-{{OPS_SLUG}}-lead footing}"

git add -A
# Commit only when there is something staged (a re-run with nothing new is a
# no-op, not an error); a genuine commit failure is NOT masked by `|| true`.
if ! git diff --cached --quiet; then
  git commit -m "chore: footing — pour lead structure and wire remotes"
fi

# GIT PUSH AUTH (lead-n7dq S1): wire git HTTPS authentication from the exported
# GITHUB_TOKEN BEFORE the push so it is non-interactive (no username/password
# prompt). Tokenize the origin URL with the PAT (x-access-token) and disable
# the terminal credential prompt belt-and-suspenders.
export GIT_TERMINAL_PROMPT=0
git remote set-url origin "https://x-access-token:${GITHUB_TOKEN}@github.com/$GITHUB_ORG/$PRODUCT-lead.git"
git push -u origin HEAD

# DOLT-OVER-GIT (lead-n7dq): the bd dolt remote is a dolt-over-git remote to a
# freshly created EMPTY GitHub repo. COMMIT the pending dolt changes first so
# there is a dolt commit to push to the empty remote (a bare push with nothing
# committed has nothing to send). `bd dolt commit` is a no-op when there is
# nothing pending, so this is safe on a re-run.
bd dolt commit -m "footing: initial beads tracker state" 2>/dev/null || true
bd dolt push origin

# -----------------------------------------------------------------------
# Step 6 — STOP at footing.
#
# Footing is reached. This script deliberately does NOT enter product
# Discovery and does NOT create any BC — those are downstream, agent-driven
# steps a human starts only after confirming this footing. The runway ends
# here, on purpose.
# -----------------------------------------------------------------------
echo "footing: solid footing reached for ${PRODUCT}-lead." >&2
echo "footing: stopping here — product Discovery and BC creation are downstream, agent-driven steps and are NOT part of footing." >&2
