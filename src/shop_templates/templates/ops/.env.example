# {{OPS_SLUG}} lead-shop environment — PLACEHOLDER values only.
#
# Brief 011 Step 2: `cp .env.example .env`, then fill in the real values.
# This file is shop-owned and committed; the resulting `.env` is git-ignored
# and carries the live credentials. NEVER commit real secret material here —
# every value below is a placeholder for the operator to replace.
#
# The agent-vault credential broker ({{OPS_SLUG}}-agent-vault in compose.yaml)
# reads AGENT_VAULT_MASTER_PASSWORD to auto-unseal; bin/shop-shell sources the
# broker coordinates (address + token) to wire the HTTPS proxy.

# Broker master password — auto-unseals the {{OPS_SLUG}}-agent-vault broker.
# Replace with the master password generated when the broker was provisioned.
AGENT_VAULT_MASTER_PASSWORD=<changeme-broker-master-password>

# Broker coordinates that bin/shop-shell sources. bin/agent-vault-provision
# replaces these <changeme-...> placeholders in the resulting .env after it
# provisions the broker, so a plain `cp .env.example .env` carries the full set.
# Broker ADDRESS — the URL the shop-shell reaches the broker API on.
AGENT_VAULT_ADDR=<changeme-broker-address>
# Broker TOKEN — the auth token the shop-shell presents to the broker.
AGENT_VAULT_TOKEN=<changeme-broker-token>
# Broker VAULT — the launch vault selector (slug-derived) launch reads.
AGENT_VAULT_VAULT=<changeme-broker-vault>
# Broker CA — path to the root CA PEM the BC trusts the MITM proxy with
# (bin/agent-vault-provision fetches it via `agent-vault ca fetch`).
AGENT_VAULT_CA_PEM=<changeme-broker-ca-pem>
