#!/usr/bin/env bash
# bin/agent-vault-provision — one-time credential provisioning for the
# product's agent-vault broker (shop-owned, PDR-003 path F).
#
# Provisions the long-lived secrets the agent-vault broker injects on the
# wire for the bc-launcher containers and the daily-driver shell: the GitHub PAT,
# any plain API tokens, AND the refreshing Claude-OAuth credential. Run it
# once per product after `docker compose up -d agent-vault`.
#
# PRODUCT-SCOPED (lead-w87b / WS-2): the broker CONTAINER, the VAULT name,
# and the docker NETWORK all derive from the bootstrap product slug
# ({{OPS_SLUG}}) so this script never targets another product's broker. The
# broker container name matches the agent-vault service compose.yaml defines
# ({{OPS_SLUG}}-agent-vault) so provisioning lands on the compose-defined
# broker. Every product-scoped token is rendered from the slug; none is
# hardcoded to a specific product's broker container or vault name.
#
# REAL CLI SURFACE (lead-beym / ADR-026 D2): the GitHub-PAT path is scripted
# against the REAL agent-vault 0.32.0 command surface — owner-account
# registration (`auth register`) -> vault (`vault create`) -> credential
# (`vault credential set`) -> service (`vault service add`, github.com Basic
# brokered over the single MITM proxy listener at :14322) -> agent token
# (`agent create <slug>-fleet --token-only`). agent-vault 0.32.0 has NO
# `put`/`store` verb; every invocation below is one of the real top-level
# verbs (account/agent/auth/ca/catalog/master-password/owner/run/server/
# user/vault/version). After provisioning, the real broker address and the
# minted `av_agt_...` fleet token are written back into .env (Brief 011 Step 4
# — the fleet token wires shop-shell + the BC launches).
#
# HUMAN GATE (ADR-026 D4 / PDR-017): the Claude-OAuth credential is a
# refreshing OAuth credential type. On agent-vault 0.32.0 it IS scriptable via
# the structured credential-slot path: `vault proposal create -f -` (stdin
# JSON) creates a pre-populated OAuth-typed CLAUDE_OAUTH credential SLOT
# (carrying the token_url refresh machinery), and the operator's role drops to
# APPROVING that proposal — pasting the real token at the printed approve URL
# (or Connect). This CORRECTS the prior lead-5jbc note that the OAuth type was
# unscriptable: that probe only tested the flat `--credential KEY=desc` (static)
# path, not the JSON-mode oauth slot (verified lead-yrex against a throwaway
# infisical/agent-vault broker, same image as the live fleet broker). ADR-026
# D4 is preserved: a human still supplies the real secret, AT APPROVE TIME.
# This script therefore CREATES the proposal and STOPS for the operator to
# approve it; it is the ONE documented human step (approval, not a hand paste).
set -euo pipefail

# Source the single ops-coordinates artifact (ADR-043 Phase 1) — the broker
# container, vault, network, and address come from OPS_* defined there; this
# script re-derives none of them.
source "$(dirname "${BASH_SOURCE[0]}")/ops-coordinates"

# -----------------------------------------------------------------------
# Broker coordinates — referenced from the sourced ops-coordinates artifact
# (nothing here is hardcoded to a product).
# -----------------------------------------------------------------------
SLUG="$OPS_SLUG"
# The broker container compose.yaml brings up (container_name:
# <slug>-agent-vault). Override only if you renamed the compose service.
CONTAINER="${AGENT_VAULT_CONTAINER:-$OPS_AGENT_VAULT_CONTAINER}"
# The logical vault/namespace the broker stores this product's secrets under
# (slug-derived, NOT a shared fixed namespace) so two products never share a vault.
VAULT="${AGENT_VAULT_VAULT:-$OPS_VAULT_NAME}"
# The docker network the broker and its clients share.
NETWORK="${AGENT_VAULT_NETWORK:-$OPS_NETWORK}"
# The broker API address the in-network clients (shop-shell, bc-launcher
# containers) reach. On the shared docker network the broker is addressable
# by its container name on the fixed API port 14321 (compose maps it to a
# slug-derived HOST port, but in-network traffic uses the container port).
# LOCAL-FIRST (lead-mrn2): agent-vault runs on the LEAD HOST and targets the
# broker over the product compose network at AGENT_VAULT_ADDR. Default is the
# in-network broker address (the lead is attached to the product network); a
# .env / env override wins. This is the address the auth session below binds.
AGENT_VAULT_ADDR="${AGENT_VAULT_ADDR:-$OPS_AGENT_VAULT_ADDR}"
BROKER_ADDR="$AGENT_VAULT_ADDR"
# The MITM HTTPS proxy listener the broker exposes (fixed container port).
# ADR-026 D2: BOTH the github.com Basic leg and the agent's outbound traffic
# broker over this single proxy listener.
PROXY_PORT="14322"
# The repo-local .env this script updates with the real broker addr + the
# minted fleet token (replacing the <changeme-...> placeholders).
ENV_FILE="${AGENT_VAULT_ENV_FILE:-.env}"

# Owner-account bootstrap credentials. The FIRST account registered on a
# fresh broker becomes the instance owner (verified: `auth register` ->
# "The first user to register becomes the instance owner."). These default
# to env-supplied values; the password is read from stdin (never on argv).
OWNER_EMAIL="${AGENT_VAULT_OWNER_EMAIL:-owner@${SLUG}.local}"
OWNER_PASSWORD="${AGENT_VAULT_OWNER_PASSWORD:-}"

# GitHub Basic-auth identity. For github.com over Basic the token is the
# password; the username is the GitHub login (or the token itself — GitHub
# accepts any non-empty username when a token is the password). Defaults to
# the conventional token-as-username form when unset. The credential KEY
# names mirror the live fleet vault's AUTHORITATIVE keys: GITHUB_USERNAME /
# GITHUB_TOKEN (SCREAMING_SNAKE — agent-vault rejects kebab credential keys).
GITHUB_USERNAME="${GITHUB_USERNAME:-x-access-token}"

# Claude-OAuth config (lead-yrex). The refreshing CLAUDE_OAUTH credential is
# provisioned as an OAuth-TYPED credential-slot PROPOSAL; these vars fill the
# oauth block the broker validates (token_url is REQUIRED on 0.32.0). Defaults
# are the values verified from the live broker's working OAuth form; a future
# Anthropic-endpoint change is a one-line override here.
CLAUDE_OAUTH_TOKEN_URL="${CLAUDE_OAUTH_TOKEN_URL:-https://console.anthropic.com/v1/oauth/token}"
CLAUDE_OAUTH_CLIENT_ID="${CLAUDE_OAUTH_CLIENT_ID:-9d1c250a-e61b-44d9-88ed-5944d1962f5e}"
# Anthropic's token endpoint required no scopes in the live form; empty default.
CLAUDE_OAUTH_SCOPES="${CLAUDE_OAUTH_SCOPES:-}"

echo "agent-vault-provision: provisioning broker '$CONTAINER' (vault '$VAULT', network '$NETWORK')."

# LOCAL-FIRST (lead-mrn2): every agent-vault verb runs on the LEAD HOST and
# targets the broker at AGENT_VAULT_ADDR via the auth session established below
# — NOT `docker exec` into the broker container. The owner `auth register` /
# `auth login` binds the session to "$AGENT_VAULT_ADDR" (its --address flag),
# and the verbs that follow inherit that session address. A broker that is
# unreachable at AGENT_VAULT_ADDR fails the auth step below, which is the
# reachability gate (no docker liveness pre-check is needed for the local path).

# -----------------------------------------------------------------------
# (0) Owner-account bootstrap (ADR-026 D2). The first registrant becomes the
#     instance owner; on a re-run the account already exists, so a failing
#     register is non-fatal (we proceed with the existing owner session).
# -----------------------------------------------------------------------
if [[ -n "$OWNER_PASSWORD" ]]; then
  echo "agent-vault-provision: registering instance owner '$OWNER_EMAIL' (first registrant = owner)."
  if ! printf '%s' "$OWNER_PASSWORD" | agent-vault auth register --address "$AGENT_VAULT_ADDR" --email "$OWNER_EMAIL" --password-stdin 2>/dev/null; then
    echo "agent-vault-provision: owner already registered (or register declined); logging in instead."
    printf '%s' "$OWNER_PASSWORD" | agent-vault auth login --address "$AGENT_VAULT_ADDR" --email "$OWNER_EMAIL" --password-stdin
  fi
else
  echo "agent-vault-provision: AGENT_VAULT_OWNER_PASSWORD not set; assuming an" >&2
  echo "  owner session already exists for '$AGENT_VAULT_ADDR'. Export it to bootstrap" >&2
  echo "  the owner non-interactively." >&2
fi

# -----------------------------------------------------------------------
# (1) Vault + GitHub PAT + service wiring — provisioned non-interactively
#     against the slug-derived broker/vault using ONLY real 0.32.0 verbs.
#
#     ADR-026 D2 flow: vault create -> credential set -> service add
#     (github.com Basic, brokered over the single MITM proxy listener).
# -----------------------------------------------------------------------
# BROKER-LOCAL credential ops (lead-0j7o / PDR-022 b0d1e504): on agent-vault
# 0.32.0 the CREDENTIAL operations (vault create / credential set) work ONLY
# broker-locally — through the owner REMOTE scoped session (or a fleet token)
# they fail 'Member role required' (lead-0j60, live-confirmed). Establish a
# broker-local owner session INSIDE the broker container and run the credential
# ops via `docker exec`, NOT the owner remote session.
DEXEC_LOCAL=(docker exec -i "$CONTAINER")
if [[ -n "$OWNER_PASSWORD" ]]; then
  printf '%s' "$OWNER_PASSWORD" | "${DEXEC_LOCAL[@]}" agent-vault auth login --email "$OWNER_EMAIL" --password-stdin >/dev/null 2>&1 \
    || printf '%s' "$OWNER_PASSWORD" | "${DEXEC_LOCAL[@]}" agent-vault auth register --email "$OWNER_EMAIL" --password-stdin >/dev/null 2>&1 || true
fi

echo "agent-vault-provision: ensuring vault '$VAULT' exists on '$CONTAINER' (broker-local)."
# `vault create` is idempotent for our purposes: a re-run on an existing
# vault is non-fatal (we still need it to exist). Broker-local docker-exec.
"${DEXEC_LOCAL[@]}" agent-vault vault create "$VAULT" 2>/dev/null || true

GITHUB_TOKEN="${GITHUB_TOKEN:-}"
if [[ -n "$GITHUB_TOKEN" ]]; then
  echo "agent-vault-provision: storing GitHub credential into vault '$VAULT' on '$CONTAINER' (broker-local)."
  # `vault credential set <key=value> ...` — the github username + token are
  # stored under the live fleet vault's AUTHORITATIVE SCREAMING_SNAKE keys, via
  # broker-local docker-exec (NOT the owner remote scoped session — Member-role).
  "${DEXEC_LOCAL[@]}" agent-vault vault credential set \
    "GITHUB_USERNAME=${GITHUB_USERNAME}" \
    "GITHUB_TOKEN=${GITHUB_TOKEN}" \
    --vault "$VAULT"

  echo "agent-vault-provision: wiring github-git (github.com Basic) over the MITM proxy (:$PROXY_PORT)."
  # `vault service add` upserts the service by name. The PRESERVED existing
  # clone/git service is named github-git: github.com brokered with Basic
  # auth, username-key + password-key referencing the credentials stored
  # above. Both legs broker over the single proxy listener (ADR-026 D2).
  agent-vault vault service add \
    --name github-git \
    --host github.com \
    --auth-type basic \
    --username-key GITHUB_USERNAME \
    --password-key GITHUB_TOKEN \
    --vault "$VAULT"

  echo "agent-vault-provision: wiring github-api (api.github.com Bearer) over the MITM proxy."
  # github-api: the REST/GraphQL API host attaches GITHUB_TOKEN as a Bearer.
  agent-vault vault service add \
    --name github-api \
    --host api.github.com \
    --auth-type bearer \
    --token-key GITHUB_TOKEN \
    --vault "$VAULT"
else
  echo "agent-vault-provision: GITHUB_TOKEN not set in the environment; skipping the"
  echo "  scripted GitHub credential store + github-git/github-api service-adds."
  echo "  Export GITHUB_TOKEN (and optionally GITHUB_USERNAME) and re-run."
fi

# -----------------------------------------------------------------------
# (1b) Claude broker service mappings (lead-8jar / WS-2). The live fleet
#      vault carries three Claude services that attach the refreshing
#      CLAUDE_OAUTH credential as a Bearer. Without these the broker never
#      attaches the OAuth bearer to api.anthropic.com requests, so a fresh
#      BC's Claude calls return 401 (dummyco spike iter-6).
#
#      These `service add` calls only DECLARE the host -> CLAUDE_OAUTH
#      mapping; the CLAUDE_OAUTH credential itself is supplied later via the
#      OAuth-proposal human gate (step 3, the operator approves the proposal).
#      agent-vault upserts the service mapping independently of whether the
#      credential exists yet, so these run UNCONDITIONALLY (the mapping is what
#      makes the bearer attach once the human-gated approval lands).
# -----------------------------------------------------------------------
echo "agent-vault-provision: wiring the Claude broker services (bearer CLAUDE_OAUTH) over the MITM proxy."
agent-vault vault service add \
  --name claude-api \
  --host api.anthropic.com \
  --auth-type bearer \
  --token-key CLAUDE_OAUTH \
  --vault "$VAULT"
agent-vault vault service add \
  --name claude-platform \
  --host platform.claude.com \
  --auth-type bearer \
  --token-key CLAUDE_OAUTH \
  --vault "$VAULT"
agent-vault vault service add \
  --name claude-mcp-proxy \
  --host mcp-proxy.anthropic.com \
  --auth-type bearer \
  --token-key CLAUDE_OAUTH \
  --vault "$VAULT"

# -----------------------------------------------------------------------
# (2) Mint the <slug>-fleet agent token (ADR-026 D2 / Brief 011 Step 4).
#
#     `agent create <name> --token-only --vault <vault>:proxy` prints the
#     raw `av_agt_...` token on stdout. This is the long-lived fleet token
#     that wires the shop-shell + every bc-launcher container's
#     AGENT_VAULT_TOKEN. We capture it and write it (plus the broker addr)
#     back into .env, replacing the <changeme-...> placeholders.
# -----------------------------------------------------------------------
# The fleet agent name is slug-derived ({{OPS_SLUG}}-fleet) and rendered as a
# literal at bootstrap so the minted agent is product-scoped.
FLEET_AGENT="{{OPS_SLUG}}-fleet"
echo "agent-vault-provision: minting the '$FLEET_AGENT' agent token (vault '$VAULT')."
FLEET_TOKEN="$(agent-vault agent create "$FLEET_AGENT" --token-only --vault "${VAULT}:proxy" | tr -d '\r\n')"

if [[ -z "$FLEET_TOKEN" ]]; then
  echo "agent-vault-provision: failed to mint the '$FLEET_AGENT' agent token." >&2
  exit 1
fi

# Fetch the broker root CA the in-network clients need to trust the MITM
# proxy (lead-71tq). `agent-vault ca fetch` prints the root CA PEM. The PEM
# is multi-line and unsafe to inline in a .env value, so we write it to a
# CA file next to the .env and point AGENT_VAULT_CA_PEM at that PATH — the
# form shop-shell/launch installs into the client trust store. (If the
# launch path ever expects inline PEM instead, switch this to capture the
# PEM into the value with proper escaping; path is the safer default.)
CA_PEM_FILE="${AGENT_VAULT_CA_PEM:-agent-vault-ca.pem}"
echo "agent-vault-provision: fetching broker root CA into '$CA_PEM_FILE'."
agent-vault ca fetch > "$CA_PEM_FILE"

# Write the real broker addr + fleet token + vault selector + CA path into .env,
# UPSERTING each key — rewrite the line if present (replacing any <changeme>
# placeholder), ELSE append it (lead-qswi). bin/bootstrap PRE-CREATES .env (with
# only a BC_BASE_IMAGE_RESOLVED line, no AGENT_VAULT_* placeholders), so a
# rewrite-only path would never land these keys and shop-shell + the BC launches
# would get NO broker credentials. The upsert guarantees all four land regardless
# of whether the placeholders exist, each exactly once, none left as <changeme>.
# (Same bug class as lead-7s4k's footing env-init upsert.)
echo "agent-vault-provision: writing AGENT_VAULT_ADDR + AGENT_VAULT_TOKEN + AGENT_VAULT_VAULT + AGENT_VAULT_CA_PEM into '$ENV_FILE'."
touch "$ENV_FILE"
_av_found_addr="" ; _av_found_token="" ; _av_found_vault="" ; _av_found_ca=""
tmp_env="$(mktemp)"
while IFS= read -r line || [[ -n "$line" ]]; do
  case "$line" in
    AGENT_VAULT_ADDR=*)   printf 'AGENT_VAULT_ADDR=%s\n' "$BROKER_ADDR";   _av_found_addr=1 ;;
    AGENT_VAULT_TOKEN=*)  printf 'AGENT_VAULT_TOKEN=%s\n' "$FLEET_TOKEN";  _av_found_token=1 ;;
    AGENT_VAULT_VAULT=*)  printf 'AGENT_VAULT_VAULT=%s\n' "$VAULT";        _av_found_vault=1 ;;
    *)                    printf '%s\n' "$line" ;;
  esac
done < "$ENV_FILE" > "$tmp_env"
# Append any key the .env did not already carry (the bin/bootstrap pre-created
# case) so every coordinate lands exactly once.
[[ -n "$_av_found_addr"  ]] || printf 'AGENT_VAULT_ADDR=%s\n'   "$BROKER_ADDR" >> "$tmp_env"
[[ -n "$_av_found_token" ]] || printf 'AGENT_VAULT_TOKEN=%s\n'  "$FLEET_TOKEN" >> "$tmp_env"
[[ -n "$_av_found_vault" ]] || printf 'AGENT_VAULT_VAULT=%s\n'  "$VAULT" >> "$tmp_env"
mv "$tmp_env" "$ENV_FILE"

# -----------------------------------------------------------------------
# (3) Claude-OAuth refreshing credential — THE HUMAN GATE (ADR-026 D4).
#
# On agent-vault 0.32.0 the refreshing OAuth credential type IS scriptable via
# the structured credential-slot path (verified lead-yrex). We CREATE a
# pre-populated OAuth-TYPED CLAUDE_OAUTH credential SLOT proposal via the CLI
# JSON mode `vault proposal create -f -` (stdin), then STOP for the operator to
# APPROVE it — pasting the real token at the printed approve URL (ADR-026 D4: a
# human still supplies the secret, at approve time). The slot carries
# oauth.token_url (the refresh machinery); the slot stores no token yet (the
# server rejects a stored token for oauth creds — tokens arrive via the
# approve/connect flow). This REPLACES the prior manual hand-paste step.
# -----------------------------------------------------------------------
# VAULT-SCOPED SESSION (lead-9qdn / WALL-2). agent-vault 0.32.0 runs proposal
# create/approve in AGENT mode: they require a vault-SCOPED session, even though
# the owner session that authorized `vault create` / `credential set` /
# `service add` above succeeded. The owner session alone yields
# "Error: Session requires vault scope". So before the proposal step we mint a
# vault-scoped session token (`vault token --vault <vault>` prints an
# `av_sess_...` to stdout, authorized off the in-container owner session) and run
# every proposal subcommand under it via AGENT_VAULT_TOKEN/_ADDR/_VAULT env vars.
# (CLI surface verified against agent-vault 0.32.0; fix proven live against a
# throwaway broker.)
echo "agent-vault-provision: minting a vault-scoped session for the proposal step on vault '$VAULT'."
_SCOPED_SESSION="$(agent-vault vault token --vault "$VAULT" --address "$AGENT_VAULT_ADDR" | tr -d '\r\n')"
if [[ -z "$_SCOPED_SESSION" ]]; then
  echo "agent-vault-provision: failed to mint a vault-scoped session for vault '$VAULT'." >&2
  echo "  proposal create/approve require a vault-scoped session on agent-vault 0.32.0." >&2
  exit 1
fi

# Run the proposal subcommands LOCALLY under the vault-scoped session — the
# three env vars are exactly: the minted scoped session as AGENT_VAULT_TOKEN,
# the broker address AGENT_VAULT_ADDR (the local-first lead<->broker address,
# NOT the in-container localhost), and the vault selector. Passed as env to a
# local `agent-vault`, NOT a docker exec into the broker.
DEXEC_SCOPED=(env \
  AGENT_VAULT_TOKEN="$_SCOPED_SESSION" \
  AGENT_VAULT_ADDR="$AGENT_VAULT_ADDR" \
  AGENT_VAULT_VAULT="$VAULT")

echo "agent-vault-provision: creating the CLAUDE_OAUTH OAuth-typed credential-slot proposal on vault '$VAULT' (vault-scoped session)."

# Render the proposal JSON from the script vars (so an Anthropic-endpoint
# change is a one-line edit above). action:set + type:oauth + the oauth block
# (token_url REQUIRED, client_id pre-filled, scopes); the slot stores no token
# (server-rejected for oauth creds); the interactive consent URL is omitted so
# approval shows the token-paste path (the realistic Claude case — we approve
# with a pasted token).
_oauth_proposal_json="$(cat <<EOF
{"credentials":[{"action":"set","key":"CLAUDE_OAUTH","type":"oauth","oauth":{"token_url":"${CLAUDE_OAUTH_TOKEN_URL}","client_id":"${CLAUDE_OAUTH_CLIENT_ID}","scopes":"${CLAUDE_OAUTH_SCOPES}"},"description":"Claude OAuth","obtain_instructions":"paste accessToken+refreshToken from ~/.claude/.credentials.json at approve time"}],"message":"Provision the refreshing CLAUDE_OAUTH credential for the claude-* broker services (vault ${VAULT})."}
EOF
)"

# `vault proposal create -f -` reads the JSON body from stdin and (with --json)
# prints the created proposal as JSON; capture it so we can surface the proposal
# number/URL in the approve prompt below.
_proposal_out="$(printf '%s' "$_oauth_proposal_json" | "${DEXEC_SCOPED[@]}" agent-vault vault proposal create -f - --json --vault "$VAULT")"

# Surface the proposal number for the operator. The number is parsed from the
# `proposal create --json` output (a "number"/"id" field); if the exact field
# shape varies, fall back to the newest pending proposal in `proposal list`.
# (Most robust portable parse: pull the first integer after a number/id key.)
PROPOSAL_NUM="$(printf '%s' "$_proposal_out" | grep -oE '"(number|id)"[[:space:]]*:[[:space:]]*[0-9]+' | grep -oE '[0-9]+' | head -n1)"
if [[ -z "$PROPOSAL_NUM" ]]; then
  # Fallback parse (lead-21uk): take the proposal's IDENTITY number — the leading
  # "#" column, the FIRST number on a pending data row — NOT `tail -n1`, which
  # grabbed the trailing CREATED-timestamp minutes and produced 'Proposal #N not
  # found'. (Now that provision OWNS the proposal-create, the fix lives here.)
  PROPOSAL_NUM="$("${DEXEC_SCOPED[@]}" agent-vault vault proposal list --status pending --vault "$VAULT" 2>/dev/null \
    | grep -F 'pending' | head -n1 | grep -oE '[0-9]+' | head -n1)"
fi
# Persist the create-time identity number into .env as CLAUDE_OAUTH_PROPOSAL_NUM
# so bin/agent-vault-approve-claude approves the RIGHT proposal by its "#" (not a
# re-parsed timestamp digit, lead-21uk). Upsert it (append-if-absent).
if [[ -n "$PROPOSAL_NUM" ]]; then
  touch "$ENV_FILE"
  if grep -q '^CLAUDE_OAUTH_PROPOSAL_NUM=' "$ENV_FILE" 2>/dev/null; then
    sed -i "s|^CLAUDE_OAUTH_PROPOSAL_NUM=.*|CLAUDE_OAUTH_PROPOSAL_NUM=$PROPOSAL_NUM|" "$ENV_FILE"
  else
    printf 'CLAUDE_OAUTH_PROPOSAL_NUM=%s\n' "$PROPOSAL_NUM" >> "$ENV_FILE"
  fi
fi

# -----------------------------------------------------------------------
# LEAD-PRESENTABLE HANDOFF (PDR-019 U6 / ADR-040 D2). The non-OAuth inputs
# (owner password, GitHub username/PAT) all arrived via env/args above with NO
# interactive prompt. The ONE genuine human step that remains — approving the
# CLAUDE_OAUTH proposal with the real secret — is isolated here into a clean
# handoff the lead can present to the user: provision REPORTS the proposal
# NUMBER together with the EXACT command the user runs, then RESUMES (it does
# NOT block on an interactive ENTER wait). The real Claude OAuth secret is
# supplied ONLY at approve-time by the human running that command; no automated
# step here transports it (ADR-026 D4 / lead scenario 11 preserved — the
# CLAUDE_OAUTH=<value> below stays a placeholder the user fills).
# -----------------------------------------------------------------------
cat <<EOF

  ┌──────────────────────────────────────────────────────────────────────┐
  │ HUMAN GATE — approve the Claude-OAuth proposal (one-time, lead handoff)│
  └──────────────────────────────────────────────────────────────────────┘

  A pre-populated OAuth-typed CLAUDE_OAUTH credential-slot proposal
  (#${PROPOSAL_NUM:-<see 'agent-vault vault proposal list'>}) was created on
  vault '$VAULT' (broker '$CONTAINER'). It already carries the OAuth config
  (token_url + client_id); only the real token is missing.

  PROPOSAL NUMBER: ${PROPOSAL_NUM:-<see 'agent-vault vault proposal list'>}

  Run this EXACT command to approve it — supply the real secret (the Claude
  accessToken) in place of <value> AT APPROVE TIME (ADR-026 D4); no automated
  step carries the real secret, it is pasted only here by the human:

    proposal approve ${PROPOSAL_NUM:-<num>} CLAUDE_OAUTH=<value> --yes

  proposal approve runs in AGENT mode (agent-vault 0.32.0) and therefore needs
  a VAULT-SCOPED session — run it under the scoped session env (NOT the bare
  owner session), exactly as proposal create was run above. The full invocation
  (the same exact 'proposal approve <num> CLAUDE_OAUTH=<value> --yes' command,
  run LOCALLY on the lead host under the scoped session env) is:

    env AGENT_VAULT_TOKEN=$_SCOPED_SESSION \\
        AGENT_VAULT_ADDR='$AGENT_VAULT_ADDR' \\
        AGENT_VAULT_VAULT='$VAULT' \\
      agent-vault vault proposal approve ${PROPOSAL_NUM:-<num>} CLAUDE_OAUTH=<value> --yes --vault '$VAULT'

  (Or open the printed approve URL and Connect.) agent-vault enforces
  SCREAMING_SNAKE credential keys — the claude-* services above attach this
  credential via --token-key CLAUDE_OAUTH. After approval the stored
  CLAUDE_OAUTH is the refresh-capable oauth type (it carries token_url), NOT a
  static credential.

  Provisioning of every automated step is COMPLETE; this is the only remaining
  human action. The script does NOT wait — run the approve command above when
  ready (re-run this script anytime to re-check the proposal status).

EOF

# -----------------------------------------------------------------------
# (3b) Scripted approve-claude WRITEBACK (BUGFIX lead-dui6 / scenario
#      1c054dfdc468860a). The approve-claude token CAPTURE + WRITEBACK logic
#      lives HERE, INSIDE provision — not in a separate script. When the
#      operator supplies the issued Claude token AT APPROVE-TIME via the
#      CLAUDE_OAUTH environment variable (the same token the manual broker-web
#      approval would store), this step CAPTURES it and writes the CLAUDE_OAUTH
#      credential back into the vault NON-EMPTY, equal to the captured token.
#
#      FAITHFULNESS GUARD — the defect this fixes: the writeback must carry the
#      CAPTURED token material, NEVER a blank. If token capture yields an EMPTY
#      value (CLAUDE_OAUTH set but empty), the step ABORTS with a diagnostic
#      rather than writing a blank CLAUDE_OAUTH back over the issued credential.
#
#      ADDITIVE (broker/13 @1d08c456af08d577 + broker/11 @72af524bca85f59c
#      preserved): the writeback runs ONLY when the human supplies the token at
#      approve-time. When CLAUDE_OAUTH is UNSET (the default create-time run)
#      this step is skipped — provision stays at the proposal + handoff above
#      and transports no automated real credential (ADR-026 D4).
# -----------------------------------------------------------------------
# APPROVE-CLAUDE-WRITEBACK-BEGIN
if [[ -n "${CLAUDE_OAUTH+x}" ]]; then
  # A token was supplied at approve-time (the CLAUDE_OAUTH env var is SET). We
  # CAPTURE it and must write it back NON-EMPTY; we must NEVER write a blank
  # over the issued credential. An empty capture is the defect — abort.
  _CLAUDE_OAUTH_CAPTURED="${CLAUDE_OAUTH}"
  if [[ -z "$_CLAUDE_OAUTH_CAPTURED" ]]; then
    echo "agent-vault-provision: approve-claude token capture yielded an EMPTY value." >&2
    echo "  Refusing to write a blank CLAUDE_OAUTH credential back over the issued" >&2
    echo "  credential — the manual broker-web approval stores a non-empty token, so a" >&2
    echo "  blank scripted writeback is the defect. Re-run with the real issued Claude" >&2
    echo "  token in the CLAUDE_OAUTH environment variable." >&2
    exit 1
  fi
  echo "agent-vault-provision: approve-claude writing the captured CLAUDE_OAUTH credential (non-empty) into vault '$VAULT'."
  # The writeback carries the CAPTURED token material verbatim (non-empty),
  # under the same vault-scoped session the proposal-create step used.
  "${DEXEC_SCOPED[@]}" agent-vault vault proposal approve "$PROPOSAL_NUM" \
    CLAUDE_OAUTH="$_CLAUDE_OAUTH_CAPTURED" --yes --vault "$VAULT"
  echo "agent-vault-provision: CLAUDE_OAUTH credential approved (non-empty writeback) for vault '$VAULT' (proposal #$PROPOSAL_NUM)."
fi
# APPROVE-CLAUDE-WRITEBACK-END

# ADR-026 D4 status check (NON-blocking, informational): the script does not
# wait for the human approve step (it RESUMES — the handoff above is the clean
# lead-presentable hand-off, not a blocking gate). We report whether the
# approved CLAUDE_OAUTH has already landed (e.g. on a re-run after approval),
# but a not-yet-approved proposal is the EXPECTED post-handoff state, not a
# failure — so this never exits non-zero on the pending case.
echo "agent-vault-provision: checking whether the CLAUDE_OAUTH credential is already approved in vault '$VAULT' (informational)."
if agent-vault vault credential list --vault "$VAULT" 2>/dev/null | grep -q "CLAUDE_OAUTH"; then
  echo "agent-vault-provision: CLAUDE_OAUTH already present; provisioning fully complete for vault '$VAULT' on '$CONTAINER'."
else
  echo "agent-vault-provision: CLAUDE_OAUTH not yet approved — run the approve command above when ready."
  echo "  (Check status anytime: 'agent-vault vault proposal list --vault $VAULT'.)"
fi
echo "agent-vault-provision: automated provisioning complete for vault '$VAULT' on '$CONTAINER'."
