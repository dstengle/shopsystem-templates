#!/usr/bin/env bash
# bin/shop-shell — lead-shop daily-driver shell (shop-owned, PDR-003 path F).
#
# THIN wrapper (PDR-020 slice 2 + Addendum II (b), ADR-028 D1): this script
# does NOT build or run a dedicated shell image and does NOT re-derive the
# broker proxy URL or fetch the MITM CA itself. It DELEGATES the brokered
# Claude launch to `bc-container`, run inside an ephemeral framework LAUNCHER
# image (shopsystem-bc-lead = bc-base + docker CLI). bc-base itself carries NO
# docker CLI and so cannot run `bc-container launch`; the launcher must run on
# bc-lead. The leaf-BC session the launcher stands up ALSO runs on the bc-lead
# image, handed in via `bc-container launch --image` — because the launched
# lead session is granted the host docker socket (`--mount-docker-socket`) so
# its own router can run `bc-container launch` to stand up BCs, and bc-base has
# no docker CLI to do that. The leaf is additionally attached to the slug-scoped
# compose network via `bc-container launch --network {{OPS_SLUG}}` so it can
# reach postgres + agent-vault by compose hostname (the outer launcher's
# --network does NOT attach the separate leaf container). The wrapper:
#
#   1. brings up the compose supporting services (postgres + agent-vault);
#   2. assembles the operator agent-vault credentials into an --env-file;
#   3. `docker run --rm -it` an ephemeral bc-lead launcher with the host docker
#      socket and the lead repo mounted, and inside it invokes
#      `bc-container launch --image <bc-lead> --network <slug>
#      --workspace-mount <lead-repo> --mount-docker-socket
#      --startup-prompt <lead session-start>`, standing up the leaf-BC session
#      on the bc-lead runtime image attached to the slug-scoped network; then
#   4. `bc-container attach` to drop the operator into the brokered session.
#
# Proxy-URL construction, CA sourcing, the readiness check, and the shell
# image are ALL delegated to the launcher / bc-base entrypoint — none are
# re-derived here. NO host credential or config dotfiles are ever mounted.
#
# PRODUCT-SCOPED: the data root, docker network (both the outer launcher's
# --network and the inner `bc-container launch --network`), env-file path, and
# the compose container-name greps all derive from the bootstrap product slug
# ({{OPS_SLUG}}) so this script never collides with a second product running
# alongside it. The framework image reference shopsystem-bc-lead (the launcher
# AND the leaf-BC runtime — both need the docker CLI) is the SAME product-neutral
# image for every product slug (the same exemption the agent-vault broker image
# carries in compose.yaml) — it is NOT slug-rewritten.
set -euo pipefail

# Resolve the repo root (this script lives at <repo>/bin/shop-shell).
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Persistent data root lives OUTSIDE the repo so the shop tree stays clean.
{{OPS_SLUG_UPPER}}_DATA="${{{OPS_SLUG_UPPER}}_DATA:-$HOME/.local/share/{{OPS_SLUG}}}"
export {{OPS_SLUG_UPPER}}_DATA
mkdir -p "${{OPS_SLUG_UPPER}}_DATA/pgdata"

# (1) Bring up postgres AND the agent-vault broker via compose (ADR-028 D1).
docker compose -f "$REPO_ROOT/compose.yaml" up -d postgres agent-vault

# Confirm the slug-scoped compose containers are actually running by name
# before proceeding. The container names are product-scoped ({{OPS_SLUG}}-*)
# so a second product's postgres/agent-vault never satisfies this check.
if ! docker ps --format '{{.Names}}' | grep -Eq '^{{OPS_SLUG}}-postgres$|^{{OPS_SLUG}}-agent-vault$'; then
  echo "bin/shop-shell: expected the slug-scoped compose containers ({{OPS_SLUG}}-postgres / {{OPS_SLUG}}-agent-vault) to be running, but neither was found." >&2
  echo "  Check 'docker compose -f $REPO_ROOT/compose.yaml ps'. Aborting." >&2
  exit 1
fi

# (2) Assemble the operator agent-vault credentials into an --env-file the
# ephemeral bc-base reads. The broker coordinates are sourced from a repo-local
# .env (carrying AGENT_VAULT_ADDR / AGENT_VAULT_TOKEN / AGENT_VAULT_VAULT). The
# env-file is written under the slug-scoped data root (mode 0600) so no secret
# touches the repo tree. The launcher (`bc-container launch`) is responsible for
# deriving the proxy URL and sourcing the MITM CA from these coordinates — the
# wrapper does NOT re-derive the proxy URL or fetch the CA itself.
AGENT_VAULT_ENV_FILE="${{OPS_SLUG_UPPER}}_DATA/shop-shell.env-file"
install -m 0600 /dev/null "$AGENT_VAULT_ENV_FILE"
if [[ -f "$REPO_ROOT/.env" ]]; then
  grep -E '^AGENT_VAULT_[A-Z_]+=' "$REPO_ROOT/.env" > "$AGENT_VAULT_ENV_FILE" || true
fi

# The lead session-start prompt the launched session runs — overriding the
# bc-base default BC session-start so the launched lead session runs the lead
# router session-start (prime, drain inbox, arm the watcher).
LEAD_STARTUP_PROMPT="Run the lead router session-start: load the lead skill, prime, drain the inbox, and arm the inbox watcher."

# Resolve the GID that owns the mounted docker socket so the inner non-root
# user can be granted access to it. stat -L follows the devcontainer symlink.
SOCKET_GID="$(stat -L -c '%g' /var/run/docker.sock)"

# (3) Run an EPHEMERAL bc-lead launcher (bc-base + docker CLI), mounting the
# host docker socket and the lead repo, and inside it delegate the brokered
# launch to `bc-container launch`. --image hands the launched leaf-BC session
# its bc-lead RUNTIME image (the same image the launcher runs on — the leaf
# also needs the docker CLI so its own router can run `bc-container launch`);
# --network attaches the separate leaf container to the slug-scoped compose
# network so it can reach postgres + agent-vault by compose hostname (the outer
# launcher's --network does NOT attach the leaf); --workspace-mount points the
# launched session at the live lead working tree; --mount-docker-socket grants
# the launched lead session the lead-only docker-daemon access; --startup-prompt
# overrides the BC-default session-start with the lead router session-start. The
# framework image reference shopsystem-bc-lead (launcher AND leaf-BC runtime) is
# product-neutral — the SAME tag for every product slug, not slug-rewritten to
# {{OPS_SLUG}}-bc-lead.
docker run --rm -it \
  --network {{OPS_SLUG}} \
  --env-file "$AGENT_VAULT_ENV_FILE" \
  --group-add "$SOCKET_GID" \
  -v "$REPO_ROOT:$REPO_ROOT" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -w "$REPO_ROOT" \
  ghcr.io/dstengle/shopsystem-bc-lead:latest \
  bc-container launch {{OPS_SLUG}}-lead \
    --image ghcr.io/dstengle/shopsystem-bc-lead:latest \
    --network {{OPS_SLUG}} \
    --workspace-mount "$REPO_ROOT" \
    --mount-docker-socket \
    --startup-prompt "$LEAD_STARTUP_PROMPT"

# (4) Drop the operator into the brokered session via the bc-lead launcher
# (attach takes no --image; it reattaches to the already-running leaf-BC).
exec docker run --rm -it \
  --network {{OPS_SLUG}} \
  -v "$REPO_ROOT:$REPO_ROOT" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -w "$REPO_ROOT" \
  ghcr.io/dstengle/shopsystem-bc-lead:latest \
  bc-container attach {{OPS_SLUG}}-lead
