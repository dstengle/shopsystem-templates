#!/usr/bin/env bash
# bin/bootstrap — shopsystem-starter adopter entry point (PDR-019 U1).
#
# Run ONCE in a freshly created repo made via GitHub's "Use this template"
# from shopsystem-starter. It is the adopter's single deterministic entry
# point and it produces their "<product>-lead" repo on SOLID FOOTING.
#
# ZERO-INSTALL: the only prerequisites are Docker and a GitHub account. There
# is no `pip install`, no language toolchain to set up, and no framework
# checkout — the framework lives ONLY in the published image. Everything this
# script needs (the `shop-templates` CLI, `bd`, `gh`, `claude`) runs inside
# the published bc-base/bc-launcher image, which this script pulls and runs in
# its INTERACTIVE bootstrap MODE (U2).
#
# REUSE, NOT FORK (the controlling constraint): the U3 footing orchestration
# and U4 product-naming + the single up-front auth gate are ALREADY encoded in
# the footing script (bin/footing, rendered from templates/ops/footing). This
# bootstrap does NOT re-implement any of that. It prepares the run — derives
# the product identity for the human-facing checks, resolves the floating
# image and records it in the run .env (ADR-040 D3), brings the broker up for
# the auth gate — and then DELEGATES to footing, which runs the auth gate,
# pours the lead structure, creates "<product>-lead-beads", wires the git +
# beads remotes, runs the `bd dolt push` smoke-test, and STOPS at a green
# `git push` + `bd dolt push`. Product Discovery is an explicit NEXT step the
# human starts AFTER footing — it is NOT part of this script.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

# The published bc-base image — used for the RENDER-ONLY run (`shop-templates
# bootstrap`), which does no docker work. It floats on :latest (ADR-040 D3);
# bin/bootstrap resolves the floating tag at run time below and records it.
BC_BASE_IMAGE="${BC_BASE_IMAGE:-ghcr.io/dstengle/shopsystem-bc-base:latest}"
# The published bc-LEAD image — used for the FOOTING-LAUNCH run (`bash
# ./bin/footing`). bc-base carries NO docker CLI, but footing issues
# `docker compose up` + the lead-rs0i `docker network connect` self-attach, so
# the footing launch MUST run on bc-lead (= bc-base + the docker CLI), or its
# first docker call dies with "docker: command not found" (lead-ae4h). Mirrors
# bin/shop-shell, which likewise launches its docker-using run on bc-lead.
# Env-overridable and :latest-floating, resolved + digest-recorded at run time
# exactly like BC_BASE_IMAGE (ADR-040 D3).
BC_LEAD_IMAGE="${BC_LEAD_IMAGE:-ghcr.io/dstengle/shopsystem-bc-lead:latest}"
RUN_ENV="${RUN_ENV:-$REPO_ROOT/.env}"

# =======================================================================
# (U4) Validate the repo name against the "*-lead" shape and derive
# <product>. The repo this template was used to create is almost never
# already named "<product>-lead"; rather than force the human to recreate
# the repo, offer to rename it in place via `gh repo rename`.
#
# (This is the human-facing, pre-flight copy of the same check footing makes
# authoritatively. footing re-derives and re-validates <product> itself; this
# pre-flight only surfaces the rename hint EARLY so the human fixes the name
# before the run rather than after the broker is up.)
# =======================================================================
REPO_NAME="${BOOTSTRAP_REPO_NAME:-$(basename "$REPO_ROOT")}"
case "$REPO_NAME" in
  *-lead)
    : # accepted — matches the "<product>-lead" lead-shop fork shape
    ;;
  *)
    RENAME_TARGET="${REPO_NAME}-lead"
    echo "bootstrap: this repository '$REPO_NAME' is not yet named in the \"<product>-lead\" shape." >&2
    echo "  A lead-shop repo must be named '<product>-lead'. You need NOT use the template again —" >&2
    echo "  rename this repository in place by running:" >&2
    echo "" >&2
    echo "    gh repo rename $RENAME_TARGET" >&2
    echo "" >&2
    echo "  then re-run ./bin/bootstrap from the renamed repository. Aborting." >&2
    exit 1
    ;;
esac
PRODUCT="${REPO_NAME%-lead}"
echo "bootstrap: deriving product identity '$PRODUCT' from repo name '$REPO_NAME'." >&2

# =======================================================================
# (ADR-040 D3) Resolve the floating image tag at RUN TIME and record the
# resolved digest in the run's .env. The committed compose.yaml pins NO tag;
# this is the step that makes the run reproducible — the resolved digest is
# written to .env so every container in the run uses the exact image this run
# resolved, even though the committed file floats.
# =======================================================================
echo "bootstrap: resolving the floating image '$BC_BASE_IMAGE' at run time (ADR-040 D3)." >&2
docker pull "$BC_BASE_IMAGE" >/dev/null
RESOLVED_DIGEST="$(docker inspect --format '{{index .RepoDigests 0}}' "$BC_BASE_IMAGE" 2>/dev/null || true)"
RESOLVED_DIGEST="${RESOLVED_DIGEST:-$BC_BASE_IMAGE}"
touch "$RUN_ENV"
# Record the run-resolved image so the run is reproducible without the
# committed compose pinning a tag.
if grep -q '^BC_BASE_IMAGE_RESOLVED=' "$RUN_ENV" 2>/dev/null; then
  sed -i "s|^BC_BASE_IMAGE_RESOLVED=.*|BC_BASE_IMAGE_RESOLVED=$RESOLVED_DIGEST|" "$RUN_ENV"
else
  printf 'BC_BASE_IMAGE_RESOLVED=%s\n' "$RESOLVED_DIGEST" >> "$RUN_ENV"
fi
echo "bootstrap: recorded resolved image '$RESOLVED_DIGEST' in $RUN_ENV." >&2

# =======================================================================
# (PDR-026 / lead-b2iz) BAKED-VERSION VERIFY GATE — runs BEFORE the in-image
# render below. A stale or cached :latest (or a silent pull/auth fallback to
# cache) would otherwise render an ANCIENT shop (no AGENT_VAULT_CA_PEM,
# hardcoded product name) with NO signal. Guard against it: read the PULLED
# image's baked shop-templates version from its PDR-026 provenance and refuse
# to render anything older than the expected minimum.
#
# PROVENANCE READ ONLY: the version is read from the OCI label
# "shopsystem.shop-templates.version" via `docker image inspect`, falling back
# to `printenv SHOP_TEMPLATES_VERSION` of a container started from the image.
# We invoke NEITHER `pip show` NOR any python inside the image — the version is
# baked provenance, not a runtime package query.
#
# FLOOR SOURCING: the expected minimum is an env-overridable literal kept
# CURRENT with the shop-templates version — a packaging-currency guard ties the
# default to pyproject [project].version, so each shop-templates release bump
# carries the floor forward and it tracks the framework rather than freezing.
# (Override via EXPECTED_MIN_SHOP_TEMPLATES_VERSION for local testing.)
# =======================================================================
EXPECTED_MIN_SHOP_TEMPLATES_VERSION="${EXPECTED_MIN_SHOP_TEMPLATES_VERSION:-0.52.3}"
echo "bootstrap: verifying the pulled image's baked shop-templates version against the expected minimum '$EXPECTED_MIN_SHOP_TEMPLATES_VERSION' (PDR-026 provenance) before rendering." >&2
BAKED_SHOP_TEMPLATES_VERSION="$(docker image inspect \
  --format '{{ index .Config.Labels "shopsystem.shop-templates.version" }}' \
  "$RESOLVED_DIGEST" 2>/dev/null || true)"
if [[ -z "$BAKED_SHOP_TEMPLATES_VERSION" || "$BAKED_SHOP_TEMPLATES_VERSION" == "<no value>" ]]; then
  # Label absent — fall back to the container ENV via `printenv` (still PDR-026
  # provenance; still NOT pip show / python).
  BAKED_SHOP_TEMPLATES_VERSION="$(docker run --rm "$RESOLVED_DIGEST" printenv SHOP_TEMPLATES_VERSION 2>/dev/null || true)"
fi
# version_ge A B — succeeds iff A is at or above B, ordering versions with
# `sort -V` (an empty/unreadable A sorts below any real floor and is refused).
version_ge() { [[ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | head -n1)" == "$2" ]]; }
if version_ge "$BAKED_SHOP_TEMPLATES_VERSION" "$EXPECTED_MIN_SHOP_TEMPLATES_VERSION"; then
  echo "bootstrap: pulled image baked shop-templates version '$BAKED_SHOP_TEMPLATES_VERSION' is at or above the expected minimum '$EXPECTED_MIN_SHOP_TEMPLATES_VERSION'; proceeding to render." >&2
else
  # REFUSE LOUDLY (scenario e9d64a8acc917efb): the pulled image is STALE. Do
  # NOT fall through to the in-image render below — rendering from a stale image
  # is the exact silent-ancient-shop bug this gate closes. Emit a diagnostic
  # that NAMES (a) the stale version read, (b) the expected minimum required,
  # and (c) an actionable remediation for obtaining the current image, then
  # exit non-zero from here so no render is ever invoked against the stale image.
  echo "bootstrap: REFUSING to render — the pulled image '$BC_BASE_IMAGE' is STALE." >&2
  echo "  baked shop-templates version read from the image (PDR-026 provenance): '${BAKED_SHOP_TEMPLATES_VERSION:-<unreadable>}'" >&2
  echo "  expected-minimum shop-templates version required by bin/bootstrap:    '$EXPECTED_MIN_SHOP_TEMPLATES_VERSION'" >&2
  echo "  Rendering from this stale image would produce an ANCIENT shop (e.g. no AGENT_VAULT_CA_PEM, a hardcoded product name); refusing." >&2
  echo "  REMEDIATION — obtain the current image, then re-run ./bin/bootstrap:" >&2
  echo "      docker pull $BC_BASE_IMAGE" >&2
  echo "      docker pull $BC_LEAD_IMAGE" >&2
  echo "  (the floating tag resolved to a cached/stale digest; a fresh pull of the published image obtains the current shop-templates build). Aborting." >&2
  exit 1
fi

# Resolve the floating bc-LEAD image (the footing-launch image) the same way
# (ADR-040 D3): pull, capture the digest, and record it so the footing-launch
# run is reproducible even though the committed default floats on :latest.
echo "bootstrap: resolving the floating footing-launch (lead) image '$BC_LEAD_IMAGE' at run time (ADR-040 D3)." >&2
docker pull "$BC_LEAD_IMAGE" >/dev/null
LEAD_RESOLVED_DIGEST="$(docker inspect --format '{{index .RepoDigests 0}}' "$BC_LEAD_IMAGE" 2>/dev/null || true)"
LEAD_RESOLVED_DIGEST="${LEAD_RESOLVED_DIGEST:-$BC_LEAD_IMAGE}"
if grep -q '^BC_LEAD_IMAGE_RESOLVED=' "$RUN_ENV" 2>/dev/null; then
  sed -i "s|^BC_LEAD_IMAGE_RESOLVED=.*|BC_LEAD_IMAGE_RESOLVED=$LEAD_RESOLVED_DIGEST|" "$RUN_ENV"
else
  printf 'BC_LEAD_IMAGE_RESOLVED=%s\n' "$LEAD_RESOLVED_DIGEST" >> "$RUN_ENV"
fi
echo "bootstrap: recorded resolved footing-launch (lead) image '$LEAD_RESOLVED_DIGEST' in $RUN_ENV." >&2

# =======================================================================
# (U1/U3) OBTAIN bin/footing by RENDERING it, then DELEGATE to it.
#
# REUSE, NOT FORK: the U3 footing orchestration (the single up-front auth gate,
# the lead-structure pour, the "<product>-lead-beads" creation, the git+beads
# remote wiring, the `bd dolt push` smoke-test, and the STOP at green) lives in
# the footing script, which is rendered from the framework's
# templates/ops/footing template. The framework — including that template —
# ships ONLY in the published image; the starter fork carries bin/bootstrap but
# NOT bin/footing. So this bootstrap must first OBTAIN bin/footing by rendering
# it, and only THEN invoke it.
#
# Step 1 — RENDER bin/footing from templates/ops/footing. Running
# `shop-templates bootstrap` (the in-image CLI, zero-install on the host) pours
# the lead structure into the fork, and that pour renders bin/footing from the
# templates/ops/footing template. We run it in-container (the CLI ships only in
# the published image) so the render lands bin/footing into the mounted fork.
# =======================================================================
echo "bootstrap: rendering bin/footing from the templates/ops/footing template via in-container 'shop-templates bootstrap' (the framework ships only in the image; the starter fork carries no bin/footing)." >&2
docker run --rm \
  --env-file "$RUN_ENV" \
  -e BOOTSTRAP_MODE=interactive \
  -e FOOTING_REPO_NAME="$REPO_NAME" \
  -v "$REPO_ROOT:/workspace/$REPO_NAME" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -w "/workspace/$REPO_NAME" \
  "$RESOLVED_DIGEST" \
  shop-templates bootstrap \
    --shop-type lead \
    --shop-name "${PRODUCT}-product" \
    --target "/workspace/$REPO_NAME"

# =======================================================================
# Step 2 — INVOKE the rendered bin/footing inside the published image's
# INTERACTIVE bootstrap MODE. The footing script is the SINGLE source of the
# auth gate — the ONE up-front consolidated human gate that collects, in one
# place, the Claude OAuth credential (via an oauth-typed proposal
# create->approve), the GitHub PAT, and the agent-vault owner password — plus
# it pours/confirms the lead structure, creates "<product>-lead-beads", wires
# the git+beads remotes, runs the `bd dolt push` smoke-test, and STOPS at a
# green `git push` + `bd dolt push`. This bootstrap REUSES it — it does not
# fork it.
#
# The bc-base/bc-launcher image carries `shop-templates`, `bd`, `gh`, and
# `claude`. We run it interactively (-it) in its bootstrap MODE so the human
# can complete the single up-front auth gate (the proposal approve step), then
# the run is non-interactive through to solid footing. bin/footing was rendered
# into the fork in Step 1 above, so it exists and is invoked via `bash` (no +x
# dependency).
# =======================================================================
# REFUSE to invoke a footing that was never obtained. The render step above is
# the ONLY thing that produces bin/footing in this fork (the starter ships
# none). If that render did not produce the file, invoking `bash ./bin/footing`
# would fail opaquely with an exit-127 "No such file or directory". Guard the
# invoke with an explicit existence check FIRST: if bin/footing is absent, emit
# a diagnostic that NAMES the missing bin/footing and exit non-zero from here,
# rather than falling through to a bare exit-127.
if [[ ! -f "$REPO_ROOT/bin/footing" ]]; then
  echo "bootstrap: bin/footing is MISSING — the render step (in-container 'shop-templates bootstrap') did not produce '$REPO_ROOT/bin/footing'." >&2
  echo "  bootstrap will NOT run 'bash ./bin/footing' against a missing file (that would fail with an opaque exit-127 'No such file or directory')." >&2
  echo "  Check the render step's output above and re-run ./bin/bootstrap once bin/footing has been rendered. Aborting." >&2
  exit 1
fi

echo "bootstrap: launching the published bc-base/bc-launcher image in its INTERACTIVE bootstrap MODE to run the rendered bin/footing." >&2
# Resolve the GID that owns the mounted docker socket so the container's inner
# non-root user (vscode) can USE it. Without --group-add, vscode is not in the
# host docker-socket gid and EVERY docker command footing issues (docker ps,
# `docker compose up`, the lead-rs0i `docker network connect` self-attach) is
# permission-DENIED, blocking the footing path at its first docker call. Resolve
# the gid AT RUN TIME (never hardcoded); `stat -L` follows the devcontainer
# symlink. Mirrors bin/shop-shell's SOCKET_GID + `--group-add "$SOCKET_GID"`.
# (Scope: ONLY this footing-launch run — the earlier render-only run does no
# docker work.)
SOCKET_GID="$(stat -L -c '%g' /var/run/docker.sock)"
# ENV-FILE PLACEHOLDER HANDOFF (lead-n7dq S6): do NOT inject a placeholder
# AGENT_VAULT_MASTER_PASSWORD into the footing container's PROCESS environment.
# The run .env may still hold the "<changeme-...>" placeholder master password
# at this point; passing it via --env-file would make the broker auto-unseal
# from a placeholder. footing MATERIALIZES the real master password into the
# repo .env (mounted below) that `docker compose up` reads — so the master
# password must come from that file, never from the footing process env. Pass a
# FILTERED env-file that drops any AGENT_VAULT_MASTER_PASSWORD line.
FOOTING_ENV_FILE="$(mktemp)"
grep -v '^AGENT_VAULT_MASTER_PASSWORD=' "$RUN_ENV" > "$FOOTING_ENV_FILE" || true
# Run footing on the bc-LEAD image (carries the docker CLI), NOT bc-base
# (lead-ae4h): footing issues `docker compose up` + `docker network connect`,
# which are "docker: command not found" on bc-base.
docker run --rm -it \
  --env-file "$FOOTING_ENV_FILE" \
  -e BOOTSTRAP_MODE=interactive \
  -e FOOTING_REPO_NAME="$REPO_NAME" \
  --group-add "$SOCKET_GID" \
  -v "$REPO_ROOT:/workspace/$REPO_NAME" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -w "/workspace/$REPO_NAME" \
  "$LEAD_RESOLVED_DIGEST" \
  bash ./bin/footing

# =======================================================================
# STOP at footing. The run reached solid footing (a green `git push` + a
# green `bd dolt push`, proven inside footing). Product Discovery and BC
# creation are downstream, agent-driven steps a human starts only AFTER
# confirming this footing — they are an explicit NEXT step and are NOT part
# of this bootstrap.
# =======================================================================
echo "bootstrap: solid footing reached for ${PRODUCT}-lead." >&2
# Name the documented entry command (lead-ddb2): bootstrap returns control to the
# HOST shell, so it must tell the operator EXACTLY how to re-enter the brokered
# lead session — './bin/shop-shell' — rather than stopping at a generic "start
# prompting" that omits the entry step.
echo "bootstrap: ENTER THE LEAD SESSION — run './bin/shop-shell' from this repository to drop into the brokered lead session (it launches the bc-lead container against the product broker). This is how you re-enter the lead session." >&2
echo "bootstrap: NEXT STEP — once inside the lead session via './bin/shop-shell', product Discovery is an explicit, agent-driven step you start AFTER confirming this footing. It is NOT part of bootstrap." >&2
